{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**/*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/student", "dest": "/public/student-portal.html" },
    { "src": "/student/dashboard", "dest": "/public/student-dashboard.html" },
    { "src": "/grade/[0-9]+", "dest": "/public/grade$1.html" },
    { "src": "/activities/(.*)", "dest": "/public/activities/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
