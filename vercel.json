{
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "admin.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/admin", "dest": "/admin.js" },
    { "src": "/student", "dest": "/api/index.js" },
    { "src": "/student/dashboard", "dest": "/api/index.js" },
    { "src": "/grade*", "dest": "/api/index.js" },
    { "src": "/activities/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/out/$1" }
  ],
  "outputDirectory": "out"
}
